# =============================================================================
# PassHub — Production Environment Variables
# =============================================================================
# Copy this file and fill in real values.
# In production, set these via Cloud Run environment variables + Secret Manager.
# NEVER commit a file with real secrets to git.
# =============================================================================

# --- Application ---
ENVIRONMENT=production
DEBUG=false
LOG_JSON=true

# --- Database (Cloud SQL PostgreSQL) ---
# Format: postgresql+asyncpg://USER:PASSWORD@HOST:5432/DB
# For Cloud SQL via private IP: HOST = the private IP of the Cloud SQL instance
POSTGRES_HOST=
POSTGRES_PORT=5432
POSTGRES_USER=passhub
POSTGRES_PASSWORD=           # → Secret Manager: passhub-db-password
POSTGRES_DB=passhub

# --- Security ---
SECURITY_JWT_SECRET=         # → Secret Manager: passhub-jwt-secret (min 64 chars random)
SECURITY_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
SECURITY_JWT_REFRESH_TOKEN_EXPIRE_MINUTES=43200

# --- Google OAuth ---
SECURITY_GOOGLE_OAUTH_CLIENT_ID=        # → Secret Manager: passhub-google-client-id
SECURITY_GOOGLE_OAUTH_CLIENT_SECRET=    # → Secret Manager: passhub-google-client-secret
SECURITY_GOOGLE_OAUTH_REDIRECT_URI=https://passhub-api-XXXXX.run.app/api/v1/auth/callback

# --- Frontend URL (used for OAuth redirect after login) ---
FRONTEND_URL=https://passhub-web-XXXXX.run.app

# --- CORS (must match exactly the frontend Cloud Run URL) ---
CORS_ORIGINS=["https://passhub-web-XXXXX.run.app"]

# --- Storage (Google Cloud Storage) ---
STORAGE_PROVIDER=gcs
STORAGE_GCS_PROJECT_ID=your-gcp-project-id
STORAGE_GCS_BUCKET=passhub-documents-prod
# STORAGE_BUCKET is the fallback if GCS_BUCKET is not set — keep both equal
STORAGE_BUCKET=passhub-documents-prod

# --- AI (OpenAI) ---
AI_PROVIDER=openai
AI_MODEL=gpt-4o-mini
OPENAI_API_KEY=              # → Secret Manager: passhub-openai-api-key

# --- Public Access Portal ---
PUBLIC_PORTAL_BASE_URL=https://passhub-web-XXXXX.run.app
PUBLIC_SESSION_DURATION_MINUTES=10
PUBLIC_SIGNED_URL_DURATION_MINUTES=5
PUBLIC_MAX_FAILED_ATTEMPTS=5
PUBLIC_LOCKOUT_MINUTES=15

# --- Frontend (baked into Docker image at build time via --build-arg) ---
# These are NOT read at runtime — they are embedded by Vite during `pnpm build`
VITE_API_BASE_URL=https://passhub-api-XXXXX.run.app/api/v1
VITE_APP_NAME=PassHub
