# Copy this file to `.env` for local development. Never commit `.env`.
# All values are consumed exclusively through `apps/api/src/core/config` —
# no code in the platform reads `os.environ` directly.

# --- Application ---
APP_NAME=PassHub API
ENVIRONMENT=development
DEBUG=true
API_V1_PREFIX=/api/v1
CORS_ORIGINS=["http://localhost:5173"]
FRONTEND_URL=http://localhost:5173
LOG_LEVEL=INFO
LOG_JSON=false

# --- Database (apps/api, mirrors docker-compose `postgres` service) ---
POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_USER=passhub
POSTGRES_PASSWORD=passhub
POSTGRES_DB=passhub

# --- PgAdmin ---
PGADMIN_DEFAULT_EMAIL=admin@passhub.dev
PGADMIN_DEFAULT_PASSWORD=admin

# --- Storage (MinIO locally, swappable for GCS without domain changes) ---
STORAGE_PROVIDER=minio
STORAGE_ENDPOINT=minio:9000
STORAGE_PUBLIC_ENDPOINT=localhost:9000
STORAGE_ACCESS_KEY=passhub
STORAGE_SECRET_KEY=passhub123
STORAGE_BUCKET=passhub-documents
STORAGE_SECURE=false
MINIO_ROOT_USER=passhub
MINIO_ROOT_PASSWORD=passhub123

# --- Security ---
SECURITY_JWT_SECRET=change-me-in-production
SECURITY_JWT_ALGORITHM=HS256
SECURITY_JWT_ACCESS_TOKEN_EXPIRE_MINUTES=15
SECURITY_JWT_REFRESH_TOKEN_EXPIRE_MINUTES=43200
# Create OAuth credentials at https://console.cloud.google.com/apis/credentials
# and register SECURITY_GOOGLE_OAUTH_REDIRECT_URI as an authorized redirect URI.
SECURITY_GOOGLE_OAUTH_CLIENT_ID=
SECURITY_GOOGLE_OAUTH_CLIENT_SECRET=
SECURITY_GOOGLE_OAUTH_REDIRECT_URI=http://localhost:8000/api/v1/auth/callback

# --- Observability (disabled by default) ---
OTEL_ENABLED=false
OTEL_SERVICE_NAME=passhub-api
OTEL_EXPORTER_ENDPOINT=

# --- AI (Intelligence Platform — gated by the `ai.document_extraction.enabled`
# feature flag, off by default; see docs/intelligence-platform.md) ---
OPENAI_API_KEY=
AI_PROVIDER=openai
AI_MODEL=gpt-5.4-mini

# --- Public Access Portal (DrivePass public vehicle sharing) ---
PUBLIC_PORTAL_BASE_URL=http://localhost:5173
PUBLIC_SESSION_DURATION_MINUTES=10
PUBLIC_SIGNED_URL_DURATION_MINUTES=5
PUBLIC_MAX_FAILED_ATTEMPTS=5
PUBLIC_LOCKOUT_MINUTES=15

# --- Frontend (apps/web, must be prefixed with VITE_ to be exposed to the browser) ---
VITE_API_BASE_URL=http://localhost:8000/api/v1
